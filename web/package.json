{
  "name": "waypoints-web",
  "version": "0.1.7",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "bun run install:sdk && bun run typecheck && vite build",
    "install:sdk": "bun install --cwd ../proton-sdk/client/js && bun install --cwd ../proton-sdk/incubating/account/js",
    "preview": "vite preview",
    "typecheck": "bun scripts/typecheck.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "tauri": "tauri",
    "app": "tauri dev",
    "app:build": "tauri build"
  },
  "dependencies": {
    "@protomaps/basemaps": "^5.7.2",
    "@protontech/crypto": "2.0.1",
    "@protontech/drive-sdk": "file:../proton-sdk/client/js",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "buffer": "^6.0.3",
    "exifr": "^7.1.3",
    "heic-to": "^1.5.2",
    "maplibre-gl": "^5.24.0",
    "pmtiles": "^4.4.1",
    "proton-drive-sdk-account": "file:../proton-sdk/incubating/account/js",
    "vue": "^3.5.13",
    "vue-i18n": "^11.4.6",
    "vue-router": "^4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.0.0",
    "@tauri-apps/cli": "^2",
    "@total-typescript/tsconfig": "^1.0.4",
    "@vitejs/plugin-vue": "^5.2.1",
    "eslint": "^10.6.0",
    "eslint-plugin-better-tailwindcss": "^4.6.1",
    "eslint-plugin-vue": "^10.9.2",
    "eslint-plugin-vuejs-accessibility": "^2.5.0",
    "globals": "^17.7.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^5.4.11",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.3.7"
  }
}
