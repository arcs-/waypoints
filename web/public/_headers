/*
  Referrer-Policy: no-referrer
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  # Privacy: connect-src is the important line — the app may only talk to Proton, Photon
  # (geocoding; MapTiler stays allowed as the switch-back geocoder), Protomaps (basemap
  # tiles + font/sprite assets), and Mapterhorn (terrain), so nothing can be exfiltrated
  # to any other host.
  # 'unsafe-eval' is required by the in-browser crypto (argon2/WASM) and HEIC decoder.
  Content-Security-Policy: default-src 'self'; script-src 'self' 'wasm-unsafe-eval' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; media-src 'self' blob:; font-src 'self'; connect-src 'self' blob: data: https://*.proton.me https://photon.komoot.io https://api.maptiler.com https://api.protomaps.com https://protomaps.github.io https://download.mapterhorn.com; worker-src 'self' blob:; frame-src https://*.proton.me; base-uri 'self'; form-action 'self'; frame-ancestors 'none'
