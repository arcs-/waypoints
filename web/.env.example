VITE_PROTOMAPS_KEY=
# Only needed if geocode.ts is switched back to the MapTiler provider (default is Photon, keyless)
VITE_MAPTILER_KEY=
# Optional: enable album deep links into Proton's web app. Lift both values from any album
# URL while signed in at drive.proton.me (https://drive.proton.me/u/<slot>/photos/albums/<shareId>/...).
# Without them, "open in Proton" links fall back to the Photos home.
VITE_PROTON_PHOTOS_SHARE_ID=
VITE_PROTON_ACCOUNT_SLOT=
