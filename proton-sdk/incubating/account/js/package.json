{
    "name": "proton-drive-sdk-account",
    "private": true,
    "version": "0.0.1",
    "description": "Incubating Proton account module for login, session, and account API access",
    "main": "src/index.ts",
    "scripts": {
        "check-types": "tsc --noEmit",
        "generate-types": "bunx openapi-typescript ../../api/openapi-core.json -o ./src/api-core-types.ts && bunx openapi-typescript ../../api/openapi-auth.json -o ./src/api-auth-types.ts",
        "lint": "eslint src --ext .ts --cache --ignore-pattern '**/*-types.ts'",
        "pretty": "prettier --write $(find src -type f -name '*.ts')",
        "test": "jest src --passWithNoTests",
        "test:watch": "jest src --watch --coverage=false --passWithNoTests"
    },
    "dependencies": {
        "ky": "^1.14.3"
    },
    "devDependencies": {
        "@swc/core": "^1.12.3",
        "@swc/jest": "^0.2.38",
        "@types/jest": "^29.5.14",
        "@types/bun": "^1.3.14",
        "@types/node": "^22.15.21",
        "@typescript-eslint/eslint-plugin": "^8.55.0",
        "eslint": "^8.57.1",
        "eslint-plugin-simple-import-sort": "^13.0.0",
        "eslint-plugin-tsdoc": "^0.3.0",
        "jest": "^29.7.0",
        "openapi-typescript": "^7.4.1",
        "prettier": "^3.6.2",
        "typescript": "^5.9.3"
    },
    "peerDependencies": {
        "@protontech/crypto": "^2.0.0"
    }
}