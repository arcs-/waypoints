<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <IsPackable>true</IsPackable>
    <PackageTags>Http Cache Serialization Telemetry</PackageTags>
    <Description>Shared client infrastructure for Proton SDKs: HTTP, caching, serialization, and telemetry.</Description>
    <EmbedAllSources>true</EmbedAllSources>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
    <PackageReference Include="Microsoft.Data.Sqlite.Core" />
    <PackageReference Include="CommunityToolkit.HighPerformance" />
    <PackageReference Include="Proton.Cryptography" />
  </ItemGroup>

  <ItemGroup Condition="!$(RuntimeIdentifier.StartsWith('ios')) And !$(RuntimeIdentifier.StartsWith('osx'))">
    <PackageReference Include="SQLitePCLRaw.config.e_sqlite3" />
    <PackageReference Include="SourceGear.sqlite3" />
  </ItemGroup>

  <ItemGroup Condition="$(RuntimeIdentifier.StartsWith('ios')) Or $(RuntimeIdentifier.StartsWith('osx'))">
    <PackageReference Include="SQLitePCLRaw.bundle_sqlite3" />
    <PackageReference Include="SQLitePCLRaw.provider.sqlite3" />
  </ItemGroup>

</Project>
